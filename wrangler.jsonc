{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "xt2",
  "compatibility_date": "2026-04-16",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "."
  },
  "routes": [
    {
      "pattern": "erd.mmec.ca/xt2/*",
      "zone_name": "mmec.ca"
    }
  ],
  "observability": {
    "enabled": true
  }
}
